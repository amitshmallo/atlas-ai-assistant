ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas
REDIS_URL=redis://localhost:6379/0

# Entra ID — see README "Entra ID setup" for how to obtain these
ENTRA_TENANT_ID=
ENTRA_API_CLIENT_ID=
ENTRA_API_CLIENT_SECRET=

# Azure OpenAI (via Azure AI Foundry) — endpoint is required; leave
# AZURE_OPENAI_API_KEY unset to authenticate via `az login` locally instead
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Blob storage — defaults to the Azurite emulator (docker compose up -d).
# Leave AZURE_STORAGE_CONNECTION_STRING unset and set AZURE_STORAGE_ACCOUNT_URL
# instead when pointing at real Azure Storage (managed identity/`az login`).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_DOCUMENTS_CONTAINER=documents

# Azure AI Search — backs the search_documents MCP tool (Phase 8)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=documents

# Azure AI Document Intelligence — used by azure_functions/document_processor
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
