{
  "$schema": "https://schema.management.azure.com/schemas/0.1.0-preview/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "postgresAdminPassword": {
      "value": "${POSTGRES_ADMIN_PASSWORD}"
    },
    "entraTenantId": {
      "value": "${ENTRA_TENANT_ID}"
    },
    "entraApiClientId": {
      "value": "${ENTRA_API_CLIENT_ID}"
    },
    "entraApiClientSecret": {
      "value": "${ENTRA_API_CLIENT_SECRET}"
    },
    "aiFoundryModelVersion": {
      "value": "${AI_FOUNDRY_MODEL_VERSION}"
    }
  }
}
